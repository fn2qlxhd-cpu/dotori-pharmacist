rules_version = '2';

// 도토리 약사님 — Firestore 보안 규칙
//
// 각 기기는 익명 로그인으로 받은 uid로만 자기 자신의 문서를
// 읽고 쓸 수 있습니다.
//
// 단, 같은 FCM 토큰을 가진 중복 문서 정리를 위해
// 본인 인증 상태에서 전체 컬렉션 읽기(쿼리)를 허용합니다.
//
// (GitHub Actions 체커는 "서비스 계정"으로 접근하기 때문에
//  이 규칙과 무관하게 항상 모든 문서를 읽을 수 있습니다.)

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // 자기 문서 읽기/쓰기
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // 중복 토큰 검색을 위한 삭제 권한
      allow delete: if request.auth != null;
    }
    // 토큰 중복 쿼리 허용 (로그인된 사용자만)
    match /users/{document=**} {
      allow read: if request.auth != null;
    }
  }
}
